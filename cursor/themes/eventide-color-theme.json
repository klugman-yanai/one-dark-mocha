  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "string.comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#909298",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc Comment",
      "scope": [
        "comment.block.documentation",
        "string.quoted.docstring.multi.python",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#9a9b9f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.template"
      ],
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "String Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#f5c2e7"
      }
    },
    {
      "name": "Number",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "name": "Built-in Constant",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "User Constant",
      "scope": [
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean",
        "constant.language.python"
      ],
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Python Keyword Operator (and, or, not, in, is)",
      "scope": [
        "keyword.operator.logical.python",
        "keyword.operator.wordlike",
        "keyword.operator.word"
      ],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Keyword Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "Keyword Operator Assignment",
      "scope": [
        "keyword.operator.assignment",
        "keyword.operator.assignment.compound"
      ],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "Comparison and Arithmetic",
      "scope": [
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise"
      ],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "C/C++ Operators",
      "scope": [
        "keyword.operator.assignment.c",
        "keyword.operator.comparison.c",
        "keyword.operator.c",
        "keyword.operator.increment.c",
        "keyword.operator.decrement.c",
        "keyword.operator.bitwise.shift.c",
        "keyword.operator.assignment.cpp",
        "keyword.operator.comparison.cpp",
        "keyword.operator.cpp",
        "keyword.operator.increment.cpp",
        "keyword.operator.decrement.cpp",
        "keyword.operator.bitwise.shift.cpp",
        "keyword.operator.sizeof.c",
        "keyword.operator.sizeof.cpp",
        "keyword.operator.arithmetic.c",
        "keyword.operator.arithmetic.cpp"
      ],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "name": "Storage Type",
      "scope": "storage.type",
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "Python self/cls",
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "variable.parameter.function.language.special.cls.python",
        "variable.language.special.self.python",
        "variable.language.special.cls.python"
      ],
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language Variable (this, self, super)",
      "scope": "variable.language",
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Class / Type Name",
      "scope": [
        "entity.name.class",
        "entity.name.module",
        "entity.name.type",
        "entity.name.type.class",
        "support.class",
        "entity.name.type.namespace"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Inherited Class",
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Type Annotation / Hint",
      "scope": [
        "support.type",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "Builtin Type",
      "scope": [
        "support.type.python",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "name": "Function Name",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic.python"
      ],
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "name": "Builtin Function",
      "scope": [
        "support.function.builtin.python",
        "function.support.builtin",
        "function.support.core"
      ],
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "name": "Python Magic Method",
      "scope": [
        "support.function.magic.python",
        "support.variable.magic.python"
      ],
      "settings": {
        "foreground": "#89b4fa",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python Decorator",
      "scope": [
        "meta.function.decorator.python",
        "entity.name.function.decorator.python",
        "support.token.decorator.python",
        "meta.function.decorator.identifier.python",
        "punctuation.definition.decorator.python"
      ],
      "settings": {
        "foreground": "#cba6f7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function Argument / Parameter",
      "scope": [
        "variable.parameter",
        "variable.parameter.function",
        "variable.parameter.function.python",
        "variable.parameter.function.language.python",
        "entity.name.variable.parameter",
        "parameter.variable"
      ],
      "settings": {
        "foreground": "#fab387",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable Object / Constant",
      "scope": [
        "variable.other.object",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "name": "Variable Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.property.object"
      ],
      "settings": {
        "foreground": "#eba0ac"
      }
    },
    {
      "name": "Variable Other",
      "scope": [
        "variable.other",
        "variable.other.readwrite",
        "variable"
      ],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "name": "C Variable",
      "scope": [
        "variable.c",
        "variable.other.readwrite.c"
      ],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
